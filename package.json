{
  "name": "mini",
  "version": "0.1.0",
  "description": "Minimalist macOS markdown editor.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "package": "electron-packager . mini --platform=darwin --arch=arm64 --overwrite --out=dist --app-bundle-id=com.mini.app --app-version=0.1.0 --icon=build/icon.icns",
    "package:universal": "electron-packager . mini --platform=darwin --arch=universal --overwrite --out=dist --app-bundle-id=com.mini.app --app-version=0.1.0 --icon=build/icon.icns"
  },
  "devDependencies": {
    "electron": "^32.0.0",
    "@electron/packager": "^18.3.5"
  }
}
